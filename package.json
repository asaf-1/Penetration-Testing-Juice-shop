{
  "name": "playwright-juice-shop-security-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright automation project for a legal OWASP Juice Shop security testing demo.",
  "scripts": {
    "test": "playwright test",
    "audit": "playwright test tests/juice-shop-security.spec.ts",
    "audit:headed": "playwright test tests/juice-shop-security.spec.ts --headed",
    "docker:audit": "node scripts/prepare-artifacts.mjs && docker compose up --build --abort-on-container-exit --exit-code-from audit audit",
    "docker:down": "docker compose down --remove-orphans",
    "lab": "node scripts/local-lab.mjs",
    "juice-shop:docker": "docker run --rm -p 3000:3000 bkimminich/juice-shop",
    "report": "playwright show-report",
    "setup:browsers": "playwright install chromium",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "24.12.4",
    "typescript": "5.9.3"
  }
}
